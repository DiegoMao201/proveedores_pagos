# Nombres de variables de entorno requeridas -- NUNCA valores reales aqui.
# Los valores reales viven solo en las Environment Variables de Coolify.

# Debe ser EXACTAMENTE igual a PGRST_JWT_SECRET del servicio PostgREST,
# para que los JWT que firmamos aqui sean validos alla.
NEXTAUTH_SECRET=

# URL interna (red Docker de Coolify) del servicio PostgREST dedicado.
POSTGREST_URL=http://postgrest-pagos-proveedores:3000

# URL publica de esta app (usada por NextAuth para construir callbacks).
NEXTAUTH_URL=https://proveedores.ferreinox.co
